# Copy to .env to enable. PUBLIC_* variables are exposed to client-side
# bundles by Astro convention.
#
# Google Analytics 4 measurement ID. Leave unset (or use the example
# value) to disable analytics entirely. Analytics are also skipped on
# `npm run dev` regardless of this setting — only production builds
# (`npm run build`) emit the gtag tag, and only when the ID is set.
PUBLIC_GA_ID=G-XXXXXXXXXX
