---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import GalleryTeaser from '../components/GalleryTeaser.astro';
import Gallery from '../components/Gallery.astro';
import release from '../data/release.json';

// Schema.org SoftwareApplication payload for the home page — gives
// search engines a structured summary of the product (name, license,
// platform, current version, download URL) for richer results.
const siteUrl = Astro.site!.toString().replace(/\/$/, '');
const softwareSchema = {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'FBIde',
    description: 'FBIde is an open-source IDE for the FreeBASIC compiler. Lightweight, native, and clutter-free.',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Windows, macOS, Linux',
    softwareVersion: release.version,
    url: siteUrl,
    downloadUrl: `${siteUrl}/download.html`,
    image: `${siteUrl}/images/screenshots/dark-theme.png`,
    license: 'https://opensource.org/licenses/MIT',
    author: {
        '@type': 'Person',
        name: 'Albert Varaksin',
    },
    offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
    },
};
---
<BaseLayout activeNav="home">
    <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
    <Hero />

    <section>
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h2>About</h2>
                    <p>
                        FBIde is a simple editor built specifically for
                        <a href="https://www.freebasic.net/" rel="noopener noreferrer" target="_blank">FreeBASIC</a>. The goal is a
                        seamless, clutter-free development environment — your code on screen,
                        the tools you need a keystroke away, and nothing in your way.
                    </p>
                    <p>
                        Free, open source, and self-contained: drop the zip into any folder
                        and run. Source and issues live on
                        <a href={release.githubRepo} rel="noopener noreferrer" target="_blank">GitHub</a>.
                    </p>
                </div>

                <div class="col-md-4">
                    <h2>Features</h2>
                    <ul class="features-list">
                        <li>One-key compile, run, and quick-run, with compiler errors parsed and clickable.</li>
                        <li>Sub / Function browser with live navigation — covers <code>SUB</code>, <code>FUNCTION</code>, macros, and <code>#include</code> files.</li>
                        <li>Code formatter: keyword case conversion and full block reformatting.</li>
                        <li>Smart auto-indent that closes blocks for you — <code>DO</code> → <code>LOOP</code>, <code>IF</code> → <code>END IF</code>, …</li>
                        <li>Themed editor with bundled palettes (Borland, Modern, Obsidian, Ocean, Twilight, …).</li>
                        <li>Context-sensitive help — CHM lookup on Windows, FreeBASIC wiki fallback.</li>
                    </ul>
                </div>

                <div class="col-md-4">
                    <h2>Gallery</h2>
                    <p class="text-muted small mb-2">Click a thumbnail to view full size.</p>
                    <GalleryTeaser limit={1} />
                </div>
            </div>
        </div>
    </section>

    <Gallery />
</BaseLayout>
