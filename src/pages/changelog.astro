---
import BaseLayout from '../layouts/BaseLayout.astro';
import release from '../data/release.json';

// Pull rendered HTML from src/content/changes.md — the file is the
// canonical source of release notes; this page is just the chrome
// around it. Drop new versions on top of changes.md per release.
import { Content as Changes } from '../content/changes.md';
---
<BaseLayout
    title="FBIde changelog"
    description="Release notes for FBIde."
    activeNav="changelog"
>
    <section>
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-9">
                    <article class="changelog-content">
                        <Changes />
                    </article>
                </div>
                <aside class="col-lg-3">
                    <p class="text-muted small">
                        The full release log lives on the
                        <a href={`${release.githubRepo}/releases`}>GitHub releases page</a>.
                    </p>
                    <p class="text-muted small">
                        Source for this page: <code>src/content/changes.md</code>.
                    </p>
                </aside>
            </div>
        </div>
    </section>
</BaseLayout>
