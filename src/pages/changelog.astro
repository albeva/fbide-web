---
// Top-level /changelog.html mirrors the latest version's content so a
// bare /changelog link always lands on something useful. Each older
// version has its own subpage at /changelog/<id>.html.
import BaseLayout from '../layouts/BaseLayout.astro';
import ChangelogSidebar from '../components/ChangelogSidebar.astro';
import { getCollection, render } from 'astro:content';

const entries = (await getCollection('changelog')).sort((a, b) =>
    b.data.date.localeCompare(a.data.date)
);
const latest = entries[0];
const { Content } = await render(latest);
---
<BaseLayout
    title={`FBIde ${latest.data.version} changelog`}
    description={`Release notes for FBIde ${latest.data.version}.`}
    activeNav="changelog"
    ogType="article"
>
    <section>
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-3">
                    <ChangelogSidebar activeVersion={latest.data.version} />
                </div>
                <div class="col-lg-9">
                    <article class="changelog-content">
                        <header class="changelog-header">
                            <h1>FBIde {latest.data.version}</h1>
                            <p class="date text-muted mb-4">{latest.data.date}{latest.data.title ? ` — ${latest.data.title}` : ''}</p>
                        </header>
                        <Content />
                    </article>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
