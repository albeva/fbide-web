---
import BaseLayout from '../layouts/BaseLayout.astro';
import DownloadIcon from '../components/DownloadIcon.astro';
import release from '../data/release.json';

const changelogHref = `/changelog/${release.version}.html`;
const sourceHref = `${release.githubRepo}/releases`;
---
<BaseLayout
    title={`Download FBIde ${release.version}`}
    description={`Download FBIde ${release.version} for Windows (64-bit and 32-bit), macOS (Apple Silicon and Intel) and Linux (AppImage).`}
    activeNav="download"
>
    <section>
        <div class="container">
            <div class="row g-4">
                <div class="col-md-8">
                    <h1 class="h2 mb-1">Download FBIde {release.version}</h1>
                    <p class="text-muted mb-4">
                        Released {release.releaseDate} &middot; <a href={changelogHref}>Changelog</a>
                    </p>

                    <div class="download-card">
                        <div class="meta">
                            <h2>
                                <svg class="platform-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                                    <path d="M6.555 1.375 0 2.237v5.45h6.555V1.375zM0 13.795l6.555.933V8.313H0v5.482zm7.278-5.4.026 6.378L16 16V8.395H7.278zM16 0 7.33 1.244v6.414H16V0z"/>
                                </svg>
                                Windows
                                {release.isPrerelease && (<span class="badge text-bg-warning">Pre-release</span>)}
                            </h2>
                            <p class="mb-1">
                                Windows 7 and up.
                            </p>
                            <p class="text-muted small mb-0">
                                <strong>Note:</strong> Some versions of Windows may need the
                                <a href="https://www.microsoft.com/en-us/download/details.aspx?id=48145" rel="noopener noreferrer" target="_blank">Visual C++ 2015 Redistributable</a>.
                            </p>
                        </div>
                        <div class="download-card-actions">
                            <a class="btn btn-sm btn-primary" href={release.downloads.win64} download={`fbide-${release.version}-win64.zip`}><DownloadIcon />64-bit</a>
                            <a class="btn btn-sm btn-primary" href={release.downloads.win32} download={`fbide-${release.version}-win32.zip`}><DownloadIcon />32-bit</a>
                        </div>
                    </div>

                    <div class="download-card">
                        <div class="meta">
                            <h2>
                                <svg class="platform-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                                    <path d="M11.182.008C11.148-.03 9.923.023 8.857 1.18c-1.066 1.156-.902 2.482-.878 2.516.024.034 1.52.087 2.475-1.258.955-1.345.762-2.391.728-2.43Zm3.314 11.733c-.048-.096-2.325-1.234-2.113-3.422.212-2.189 1.675-2.789 1.698-2.854.023-.065-.597-.79-1.254-1.157a3.692 3.692 0 0 0-1.563-.434c-.108-.003-.483-.095-1.254.116-.508.139-1.653.589-1.968.607-.316.018-1.256-.522-2.267-.665-.647-.125-1.333.131-1.824.328-.49.196-1.422.754-2.074 2.237-.652 1.482-.311 3.83-.067 4.56.244.729.625 1.924 1.273 2.796.576.984 1.34 1.667 1.659 1.899.319.232 1.219.386 1.843.067.502-.308 1.408-.485 1.766-.472.357.013 1.061.154 1.782.539.571.197 1.111.115 1.652-.105.541-.221 1.324-1.059 2.238-2.758.347-.79.505-1.217.473-1.282Z"/>
                                </svg>
                                macOS
                                {release.isPrerelease && (<span class="badge text-bg-warning">Pre-release</span>)}
                            </h2>
                            <p class="mb-1">
                                macOS 11, Big Sur or later.
                            </p>
                            <p class="text-muted small mb-0">
                                <strong>Note:</strong> FBIde is not signed with an Apple Developer
                                certificate. On first launch macOS will block the app — open
                                <em>System Settings → Privacy &amp; Security</em> and click
                                <em>Open Anyway</em> to allow it.
                            </p>
                        </div>
                        <div class="download-card-actions">
                            <a class="btn btn-sm btn-primary" href={release.downloads.macosArm64} download={`fbide-${release.version}-macos-arm64.dmg`}><DownloadIcon />Apple Silicon</a>
                            <a class="btn btn-sm btn-primary" href={release.downloads.macosX64} download={`fbide-${release.version}-macos-x86_64.dmg`}><DownloadIcon />Intel</a>
                        </div>
                    </div>

                    <div class="download-card">
                        <div class="meta">
                            <h2>
                                <img class="platform-icon platform-icon-img" src="/images/icons/tux.svg" alt="" width="16" height="19" />
                                Linux
                                {release.isPrerelease && (<span class="badge text-bg-warning">Pre-release</span>)}
                            </h2>
                            <p class="mb-0">
                                Portable AppImage for x86_64. <code>chmod +x</code> the file then run it. Requires a glibc-based distro with FUSE.
                            </p>
                        </div>
                        <div class="download-card-actions">
                            <a class="btn btn-sm btn-primary" href={release.downloads.linux64} download={`fbide-${release.version}-x86_64.AppImage`}><DownloadIcon />64-bit AppImage</a>
                        </div>
                    </div>

                    <h2 class="h4 mt-5">Other downloads</h2>
                    <div class="download-card download-card-stacked">
                        <div class="download-card-row">
                            <div class="meta">
                                <h3><span aria-hidden="true">📦</span> Sources</h3>
                                <p class="mb-0">
                                    Full archive of release artefacts — source tarballs, prior builds, and complete release notes — mirrored on GitHub.
                                </p>
                            </div>
                            <div class="download-card-actions">
                                <a class="btn btn-sm btn-outline-secondary" href={sourceHref} rel="noopener noreferrer" target="_blank">GitHub releases</a>
                            </div>
                        </div>
                        <div class="download-card-row">
                            <div class="meta">
                                <h3><span aria-hidden="true">💾</span> Legacy</h3>
                                <p class="mb-0">
                                    Original FBIde 0.3.x and 0.4.x bundles from the SourceForge era, kept for reference.
                                </p>
                            </div>
                            <div class="download-card-actions">
                                <a class="btn btn-sm btn-outline-secondary" href="/download/legacy.html">Legacy releases</a>
                            </div>
                        </div>
                    </div>
                </div>

                <aside class="col-md-4">
                    <h2 class="h4">Need the compiler?</h2>
                    <p>
                        FBIde is just the editor. Grab the FreeBASIC compiler
                        (<code>fbc.exe</code>) from the official project, then point
                        FBIde at it via <em>Settings → Compiler</em>.
                    </p>
                    <p>
                        <a class="btn btn-outline-primary" href="https://www.freebasic.net/" rel="noopener noreferrer" target="_blank">
                            Download FreeBASIC &raquo;
                        </a>
                    </p>
                </aside>
            </div>
        </div>
    </section>
</BaseLayout>
