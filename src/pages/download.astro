---
import BaseLayout from '../layouts/BaseLayout.astro';
import release from '../data/release.json';

const windowsDownloads = [
    {
        label: 'FBIde for Windows (64-bit)',
        // 'Recommended' badge is reserved for final releases — auto-on
        // when release.isPrerelease flips to false.
        recommended: !release.isPrerelease,
        href: release.downloads.win64,
        filename: `fbide-${release.version}-win64.zip`,
        note: 'Requires Windows 8.1, 10 or 11.',
    },
    {
        label: 'FBIde for Windows (32-bit)',
        recommended: false,
        href: release.downloads.win32,
        filename: `fbide-${release.version}-win32.zip`,
        note: 'Requires Windows 7, 8.1, 10 or 11. Windows 7 may need the <a href="https://www.microsoft.com/en-us/download/details.aspx?id=48145" rel="noopener noreferrer" target="_blank">Visual C++ 2015 Redistributable</a> installed.',
    },
];

const macosDownloads = [
    {
        label: 'FBIde for macOS (Apple Silicon)',
        recommended: false,
        href: release.downloads.macosArm64,
        filename: `fbide-${release.version}-macos-arm64.dmg`,
        note: 'For M1/M2/M3 Macs. Requires macOS 12 Monterey or later.',
    },
    {
        label: 'FBIde for macOS (Intel)',
        recommended: false,
        href: release.downloads.macosX64,
        filename: `fbide-${release.version}-macos-x86_64.dmg`,
        note: 'For Intel Macs. Requires macOS 12 Monterey or later.',
    },
];

const linuxDownloads = [
    {
        label: 'FBIde for Linux (64-bit AppImage)',
        recommended: false,
        href: release.downloads.linux64,
        filename: `fbide-${release.version}-x86_64.AppImage`,
        note: 'Portable AppImage for x86_64. <code>chmod +x</code> the file then run it. Requires a glibc-based distro with FUSE available.',
    },
];
---
<BaseLayout
    title={`Download FBIde ${release.version}`}
    description={`Download FBIde ${release.version} for Windows (64-bit and 32-bit), macOS (Apple Silicon and Intel) and Linux (AppImage).`}
    activeNav="download"
>
    <section>
        <div class="container">
            <div class="row g-4">
                <div class="col-md-8">
                    <h1 class="h2"><span aria-hidden="true">🪟</span> Windows</h1>

                    {windowsDownloads.map((dl) => (
                        <div class="download-card">
                            <div class="meta">
                                <h3>{dl.label} {dl.recommended && (<span class="badge text-bg-success">Recommended</span>)} {release.isPrerelease && (<span class="badge text-bg-warning">Pre-release</span>)}</h3>
                                <p class="text-muted small mb-1">
                                    v{release.version}
                                    &middot; released {release.releaseDate}
                                    &middot; <a href={`/changelog/${release.version}.html`}>changelog</a>
                                </p>
                                <p class="mb-0" set:html={dl.note}></p>
                            </div>
                            <a class="btn btn-primary" href={dl.href}>Download</a>
                        </div>
                    ))}

                    <h2 class="h2 mt-4"><span aria-hidden="true">🍎</span> macOS</h2>

                    {macosDownloads.map((dl) => (
                        <div class="download-card">
                            <div class="meta">
                                <h3>{dl.label} {dl.recommended && (<span class="badge text-bg-success">Recommended</span>)} {release.isPrerelease && (<span class="badge text-bg-warning">Pre-release</span>)}</h3>
                                <p class="text-muted small mb-1">
                                    v{release.version}
                                    &middot; released {release.releaseDate}
                                    &middot; <a href={`/changelog/${release.version}.html`}>changelog</a>
                                </p>
                                <p class="mb-0" set:html={dl.note}></p>
                            </div>
                            <a class="btn btn-primary" href={dl.href}>Download</a>
                        </div>
                    ))}

                    <p class="text-muted small mt-2 mb-0">
                        <strong>Note:</strong> FBIde is not signed with an Apple Developer
                        certificate. On first launch macOS will block the app — open
                        <em>System Settings → Privacy &amp; Security</em> and click
                        <em>Open Anyway</em> to allow it.
                    </p>

                    <h2 class="h2 mt-4"><span aria-hidden="true">🐧</span> Linux</h2>

                    {linuxDownloads.map((dl) => (
                        <div class="download-card">
                            <div class="meta">
                                <h3>{dl.label} {dl.recommended && (<span class="badge text-bg-success">Recommended</span>)} {release.isPrerelease && (<span class="badge text-bg-warning">Pre-release</span>)}</h3>
                                <p class="text-muted small mb-1">
                                    v{release.version}
                                    &middot; released {release.releaseDate}
                                    &middot; <a href={`/changelog/${release.version}.html`}>changelog</a>
                                </p>
                                <p class="mb-0" set:html={dl.note}></p>
                            </div>
                            <a class="btn btn-primary" href={dl.href}>Download</a>
                        </div>
                    ))}

                    <h2 class="h4 mt-4"><span aria-hidden="true">💾</span> Other</h2>

                    <div class="download-card">
                        <div class="meta">
                            <h3>Legacy releases <span class="badge text-bg-secondary">Deprecated</span></h3>
                            <p class="text-muted small mb-1">FBIde 0.3.x / 0.4.x</p>
                            <p class="mb-0">Original SourceForge bundles, kept for reference. Windows XP and up.</p>
                        </div>
                        <a class="btn btn-outline-secondary" href="/download/legacy.html">Browse</a>
                    </div>

                    <h2 class="h4 mt-4"><span aria-hidden="true">📦</span> Source code</h2>

                    <div class="download-card">
                        <div class="meta">
                            <h3>Source archives &amp; other files</h3>
                            <p class="text-muted small mb-1">Source tarballs, prior builds, full release notes</p>
                            <p class="mb-0">Every release artefact is mirrored on the GitHub releases page.</p>
                        </div>
                        <a class="btn btn-outline-secondary" href={`${release.githubRepo}/releases`} rel="noopener noreferrer" target="_blank">GitHub</a>
                    </div>
                </div>

                <aside class="col-md-4">
                    <h2 class="h4">Need the compiler?</h2>
                    <p>
                        FBIde is just the editor. Grab the FreeBASIC compiler
                        (<code>fbc.exe</code>) from the official project, then point
                        FBIde at it via <em>Settings → Compiler</em>.
                    </p>
                    <p>
                        <a class="btn btn-outline-primary" href="https://www.freebasic.net/" rel="noopener noreferrer" target="_blank">
                            Download FreeBASIC &raquo;
                        </a>
                    </p>
                </aside>
            </div>
        </div>
    </section>
</BaseLayout>
