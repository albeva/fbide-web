---
// Shared HTML shell — navbar + footer + Bootstrap. Pages should slot
// their content into the default slot.
//
// Bootstrap is CSS-only here: a trimmed Sass build (styles/bootstrap.scss)
// supplies the styling, and the page ships no Bootstrap JS. The two
// interactive pieces — the navbar collapse below and the gallery
// dialog (Gallery.astro) — are a few lines of vanilla JS on top of the
// native <dialog> element.
// Bootstrap first so the site stylesheet can override it.
import "../styles/bootstrap.scss";
import "../styles/site.css";
import Analytics from "../components/Analytics.astro";

interface Props {
    title?: string;
    description?: string;
    activeNav?: 'home' | 'download' | 'changelog';
    /** Path under /images, or absolute URL. Defaults to the dark-theme
     *  screenshot — a representative product shot for link previews. */
    image?: string;
    /** og:type override; defaults to 'website'. Use 'article' for changelogs. */
    ogType?: string;
}

const {
    title = 'FBIde — #1 editor for FreeBASIC',
    description = 'FBIde is an open-source IDE for the FreeBASIC compiler. Lightweight, native, and clutter-free.',
    activeNav = 'home',
    image = '/images/screenshots/dark-theme.png',
    ogType = 'website',
} = Astro.props;

// Resolve absolute URLs against `site` so OG/Twitter scrapers always
// see fully qualified URLs even on pages served from subpaths.
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = new URL(image, Astro.site).toString();

const navItems = [
    { id: 'home',      label: 'Overview',  href: '/' },
    { id: 'download',  label: 'Download',  href: '/download.html' },
    { id: 'changelog', label: 'Changelog', href: '/changelog.html' },
];
---
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Albert Varaksin" />
    <meta name="keywords" content="FBIde, FreeBASIC, IDE, editor, fbc, basic, qbasic" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#2b2b2b" />

    <!-- Open Graph (Facebook, LinkedIn, Discord, …) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="FBIde" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <!-- Pre-paint theme application: read stored / system preference and
         set data-bs-theme on <html> before the body renders so we never
         flash light-mode for dark-mode users. -->
    <script is:inline>
        (function () {
            try {
                const stored = localStorage.getItem('fbide-theme');
                const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                const theme = stored === 'light' || stored === 'dark'
                    ? stored
                    : (prefersDark ? 'dark' : 'light');
                document.documentElement.setAttribute('data-bs-theme', theme);
            } catch (_) {
                document.documentElement.setAttribute('data-bs-theme', 'light');
            }
        })();
    </script>
    <Analytics />
</head>
<body>
    <nav class="navbar navbar-expand-md bg-dark sticky-top" data-bs-theme="dark" aria-label="Primary">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">FBIde</a>
            <button
                id="navToggler"
                class="navbar-toggler"
                type="button"
                aria-controls="primaryNav"
                aria-expanded="false"
                aria-label="Toggle navigation"
            >
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="primaryNav">
                <ul class="navbar-nav me-auto">
                    {navItems.map((item) => (
                        <li class="nav-item">
                            <a
                                class={`nav-link${activeNav === item.id ? ' active' : ''}`}
                                aria-current={activeNav === item.id ? 'page' : undefined}
                                href={item.href}
                            >{item.label}</a>
                        </li>
                    ))}
                </ul>
                <a class="btn btn-outline-light btn-sm" href="https://github.com/albeva/fbide" rel="noopener noreferrer" target="_blank">
                    GitHub
                </a>
                <button
                    id="themeToggle"
                    type="button"
                    class="btn btn-outline-light btn-sm ms-2 theme-toggle"
                    aria-label="Toggle colour theme"
                    title="Toggle colour theme"
                >
                    <!-- Inline Bootstrap Icons SVG (moon-stars-fill /
                         sun-fill) — avoids pulling the whole icon webfont
                         + its render-blocking CSS for two glyphs. Both
                         render; CSS picks the right one off data-bs-theme
                         (set inline before paint), so dark-mode users
                         don't see a moon flash before the sun appears. -->
                    <svg class="theme-icon theme-icon-light" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                        <path d="M6 .278a.768.768 0 0 1 .08.858 7.208 7.208 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277.527 0 1.04-.055 1.533-.16a.787.787 0 0 1 .81.316.733.733 0 0 1-.031.893A8.349 8.349 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.752.752 0 0 1 6 .278"/>
                        <path d="M10.794 3.148a.217.217 0 0 1 .412 0l.387 1.162c.173.518.579.924 1.097 1.097l1.162.387a.217.217 0 0 1 0 .412l-1.162.387a1.734 1.734 0 0 0-1.097 1.097l-.387 1.162a.217.217 0 0 1-.412 0l-.387-1.162A1.734 1.734 0 0 0 9.31 6.593l-1.162-.387a.217.217 0 0 1 0-.412l1.162-.387a1.734 1.734 0 0 0 1.097-1.097z"/>
                    </svg>
                    <svg class="theme-icon theme-icon-dark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                        <path d="M8 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8M8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0m0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13m8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5M3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8m10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0m-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0m9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707M4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708"/>
                    </svg>
                </button>
            </div>
        </div>
    </nav>

    <main>
        <slot />
    </main>

    <footer class="site-footer text-light bg-dark py-3" data-bs-theme="dark">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <p class="mb-0 small">&copy; Albert Varaksin 2004 – {new Date().getFullYear()}</p>
            <ul class="footer-badges list-unstyled mb-0">
                <li>
                    <a class="link-light small" href="https://www.freebasic.net/" rel="noopener noreferrer" target="_blank">FreeBASIC</a>
                </li>
                <li>
                    <a href="https://www.freebasic-portal.de/" rel="noopener noreferrer" target="_blank" title="Deutsche FreeBASIC-Community">
                        <img src="/images/freebasic-portal.de-logo.png" alt="FreeBASIC Portal" />
                    </a>
                </li>
                <li>
                    <a href="https://www.phatcode.net/" rel="noopener noreferrer" target="_blank" title="Phatcode">
                        <img src="/images/phatcode-logo.gif" alt="Phatcode" />
                    </a>
                </li>
            </ul>
        </div>
    </footer>

    <!-- Navbar collapse — toggle Bootstrap's .show class on the menu.
         Replaces Bootstrap's collapse plugin; the gallery dialog
         handles its own open/close, so the site ships no Bootstrap JS. -->
    <script is:inline>
        document.addEventListener('DOMContentLoaded', function () {
            const toggler = document.getElementById('navToggler');
            const nav = document.getElementById('primaryNav');
            if (!toggler || !nav) return;
            toggler.addEventListener('click', function () {
                const shown = nav.classList.toggle('show');
                toggler.setAttribute('aria-expanded', shown ? 'true' : 'false');
            });
        });
    </script>

    <!-- Theme toggle — flip data-bs-theme on <html> and persist the
         choice. Icon visibility is driven by CSS off the same
         attribute (see .theme-icon-light / .theme-icon-dark in
         site.css), so no JS is needed for the initial paint. -->
    <script is:inline>
        document.addEventListener('DOMContentLoaded', function () {
            const root = document.documentElement;
            const btn = document.getElementById('themeToggle');
            if (!btn) return;

            function syncAria() {
                btn.setAttribute(
                    'aria-pressed',
                    root.getAttribute('data-bs-theme') === 'dark' ? 'true' : 'false'
                );
            }

            syncAria();

            btn.addEventListener('click', function () {
                const next = root.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
                root.setAttribute('data-bs-theme', next);
                try {
                    localStorage.setItem('fbide-theme', next);
                } catch (_) { /* private mode etc — ignore */ }
                syncAria();
            });
        });
    </script>
</body>
</html>
