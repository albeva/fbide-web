---
// Gallery modal — full-size image area on top, thumbnail strip at the
// bottom. Arrow-key navigation while the modal is open. Triggers come
// from elsewhere (e.g. GalleryTeaser): any element with
// data-bs-target="#galleryModal" + data-index="<n>" opens this modal
// at the matching slide.
import galleryData from '../data/gallery.json';

interface GalleryItem {
    src: string;
    caption: string;
    thumb?: string;
}

const gallery = galleryData as GalleryItem[];
---
<div class="modal fade" id="galleryModal" tabindex="-1" aria-labelledby="galleryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="galleryModalLabel">FBIde in action</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="gallery-main">
                    <img id="galleryMainImage" src="" alt="" />
                </div>
                <ul class="gallery-strip list-unstyled" id="galleryStrip" role="tablist">
                    {gallery.map((item, index) => (
                        <li>
                            <button
                                type="button"
                                class="gallery-strip-thumb"
                                data-index={index}
                                aria-label={item.caption}
                            >
                                <img src={item.thumb ?? item.src} alt={item.caption} loading="lazy" />
                            </button>
                        </li>
                    ))}
                </ul>
            </div>
        </div>
    </div>
</div>

<script is:inline define:vars={{ gallery }}>
    document.addEventListener('DOMContentLoaded', () => {
        const modalEl = document.getElementById('galleryModal');
        if (!modalEl) return;

        const imgEl = modalEl.querySelector('#galleryMainImage');
        const titleEl = modalEl.querySelector('#galleryModalLabel');
        const strip = modalEl.querySelector('#galleryStrip');
        if (!imgEl || !titleEl || !strip) return;

        let current = 0;

        function show(index) {
            const total = gallery.length;
            if (total === 0) return;
            // Wrap around at both ends.
            current = ((index % total) + total) % total;
            const item = gallery[current];
            imgEl.src = item.src;
            imgEl.alt = item.caption;
            titleEl.textContent = `FBIde in action — ${item.caption}`;
            strip.querySelectorAll('button').forEach((btn, i) => {
                btn.classList.toggle('active', i === current);
                btn.setAttribute('aria-selected', i === current ? 'true' : 'false');
            });
            const active = strip.querySelector('button.active');
            if (active && active.scrollIntoView) {
                active.scrollIntoView({ block: 'nearest', inline: 'nearest', behavior: 'smooth' });
            }
        }

        // Open from a thumbnail trigger (GalleryTeaser, etc.)
        modalEl.addEventListener('show.bs.modal', (event) => {
            const trigger = event.relatedTarget;
            const raw = trigger ? trigger.getAttribute('data-index') : null;
            const index = raw === null ? 0 : parseInt(raw, 10);
            show(Number.isNaN(index) ? 0 : index);
        });

        // Strip clicks switch the active image.
        strip.addEventListener('click', (event) => {
            const btn = event.target.closest('button');
            if (!btn) return;
            const raw = btn.getAttribute('data-index');
            const index = raw === null ? 0 : parseInt(raw, 10);
            show(Number.isNaN(index) ? 0 : index);
        });

        // Arrow-key navigation while the modal is shown.
        function onKey(event) {
            if (event.key === 'ArrowLeft') {
                event.preventDefault();
                show(current - 1);
            } else if (event.key === 'ArrowRight') {
                event.preventDefault();
                show(current + 1);
            }
        }

        modalEl.addEventListener('shown.bs.modal', () => {
            document.addEventListener('keydown', onKey);
        });
        modalEl.addEventListener('hidden.bs.modal', () => {
            document.removeEventListener('keydown', onKey);
        });
    });
</script>
