---
// Gallery dialog — full-size image area on top, thumbnail strip at the
// bottom. Built on the native <dialog> element: showModal() gives a
// top-layer overlay, a ::backdrop, focus trapping and Esc-to-close for
// free — no Bootstrap JS. Triggers live elsewhere (e.g. GalleryTeaser):
// any element with data-gallery-index="<n>" opens the dialog at that
// slide.
import galleryData from '../data/gallery.json';

interface GalleryItem {
    src: string;
    caption: string;
    thumb?: string;
}

const gallery = galleryData as GalleryItem[];
---
<dialog id="galleryModal" class="gallery-dialog" aria-labelledby="galleryModalLabel">
    <div class="gallery-dialog-header">
        <h2 class="gallery-dialog-title" id="galleryModalLabel">FBIde in action</h2>
        <button type="button" class="gallery-dialog-close" data-gallery-close aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
    <div class="gallery-main">
        <img id="galleryMainImage" src="" alt="" />
    </div>
    <ul class="gallery-strip list-unstyled" id="galleryStrip" role="tablist">
        {gallery.map((item, index) => (
            <li>
                <button
                    type="button"
                    class="gallery-strip-thumb"
                    data-index={index}
                    aria-label={item.caption}
                >
                    <img src={item.thumb ?? item.src} alt={item.caption} loading="lazy" />
                </button>
            </li>
        ))}
    </ul>
</dialog>

<script is:inline define:vars={{ gallery }}>
    document.addEventListener('DOMContentLoaded', () => {
        const dialog = document.getElementById('galleryModal');
        if (!dialog) return;

        const imgEl = dialog.querySelector('#galleryMainImage');
        const titleEl = dialog.querySelector('#galleryModalLabel');
        const strip = dialog.querySelector('#galleryStrip');
        if (!imgEl || !titleEl || !strip) return;

        let current = 0;

        function show(index) {
            const total = gallery.length;
            if (total === 0) return;
            // Wrap around at both ends.
            current = ((index % total) + total) % total;
            const item = gallery[current];
            imgEl.src = item.src;
            imgEl.alt = item.caption;
            titleEl.textContent = `FBIde in action — ${item.caption}`;
            strip.querySelectorAll('button').forEach((btn, i) => {
                btn.classList.toggle('active', i === current);
                btn.setAttribute('aria-selected', i === current ? 'true' : 'false');
            });
            const active = strip.querySelector('button.active');
            if (active && active.scrollIntoView) {
                active.scrollIntoView({ block: 'nearest', inline: 'nearest', behavior: 'smooth' });
            }
        }

        function open(index) {
            show(index);
            if (!dialog.open) dialog.showModal();
        }

        // Open from any trigger in the document (GalleryTeaser tiles + CTA).
        document.querySelectorAll('[data-gallery-index]').forEach((trigger) => {
            trigger.addEventListener('click', () => {
                const raw = trigger.getAttribute('data-gallery-index');
                const index = raw === null ? 0 : parseInt(raw, 10);
                open(Number.isNaN(index) ? 0 : index);
            });
        });

        // Close: the header button, or a click on the backdrop — for a
        // modal <dialog> a backdrop click reports the dialog as target.
        dialog.querySelectorAll('[data-gallery-close]').forEach((btn) => {
            btn.addEventListener('click', () => dialog.close());
        });
        dialog.addEventListener('click', (event) => {
            if (event.target === dialog) dialog.close();
        });

        // Strip clicks switch the active image.
        strip.addEventListener('click', (event) => {
            const btn = event.target.closest('button');
            if (!btn) return;
            const raw = btn.getAttribute('data-index');
            const index = raw === null ? 0 : parseInt(raw, 10);
            show(Number.isNaN(index) ? 0 : index);
        });

        // Arrow-key navigation while the dialog is open (Esc closes natively).
        dialog.addEventListener('keydown', (event) => {
            if (event.key === 'ArrowLeft') {
                event.preventDefault();
                show(current - 1);
            } else if (event.key === 'ArrowRight') {
                event.preventDefault();
                show(current + 1);
            }
        });
    });
</script>
