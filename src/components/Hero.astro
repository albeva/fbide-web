---
// Hero band shown on the home page. Mirrors the 2012-era layout: tagline
// on the left, illustration on the right, a primary download button.
import release from '../data/release.json';
---
<header class="hero">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-md-8">
                <h1>FBIde — the editor for FreeBASIC</h1>
                <p class="lead">
                    <strong>FBIde</strong> is one of the longest-standing editors for the
                    <strong>FreeBASIC</strong> programming language. Simple, native, and
                    clutter-free, it stays out of your way so you can focus on the code.
                </p>
                <p>
                    <a class="btn btn-primary btn-lg" href="/download.html">
                        Download FBIde {release.version}
                    </a>
                    <a class="btn btn-outline-light btn-lg ms-2" href={release.githubRepo} rel="noopener noreferrer" target="_blank">
                        View on GitHub
                    </a>
                </p>
            </div>
            <div class="col-md-4 text-center">
                <img class="hero-illustration" src="/images/horse.png" alt="" loading="lazy" />
            </div>
        </div>
    </div>
</header>
