---
// Compact thumbnail grid for the home page. Each tile opens the
// gallery modal (rendered separately by Gallery.astro) at that
// thumbnail's index. Pass `limit` to truncate the grid and append a
// "More images" CTA that opens the modal at the first hidden image.
import galleryData from '../data/gallery.json';

interface GalleryItem {
    src: string;
    caption: string;
    thumb?: string;
}

interface Props {
    limit?: number;
}

const gallery = galleryData as GalleryItem[];
const { limit } = Astro.props;
const visible = limit ? gallery.slice(0, limit) : gallery;
const hasMore = limit !== undefined && gallery.length > limit;
const moreIndex = limit ?? 0;
---
<ul class="gallery-teaser list-unstyled">
    {visible.map((item, index) => (
        <li>
            <button
                type="button"
                class="gallery-teaser-thumb"
                data-bs-toggle="modal"
                data-bs-target="#galleryModal"
                data-index={index}
                aria-label={`Open: ${item.caption}`}
            >
                <img src={item.thumb ?? item.src} alt={item.caption} loading="lazy" />
            </button>
        </li>
    ))}
</ul>
{hasMore && (
    <p class="mt-3 mb-0">
        <button
            type="button"
            class="btn btn-sm btn-outline-primary"
            data-bs-toggle="modal"
            data-bs-target="#galleryModal"
            data-index={moreIndex}
        >
            More images &raquo;
        </button>
    </p>
)}
