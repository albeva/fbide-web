# Auto-detect text vs binary; normalise line endings to LF in the repo
# but keep them as-is on checkout for the active platform.
* text=auto eol=lf

# Source / config (always LF, regardless of platform).
*.astro    text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf

# Binary assets — never normalise.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.svg  text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.pdf   binary
*.zip   binary
